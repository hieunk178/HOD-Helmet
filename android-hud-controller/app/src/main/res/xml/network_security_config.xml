<?xml version="1.0" encoding="utf-8"?>
<!--
    Network security config to allow cleartext HTTP traffic
    to local network ESP32 devices.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
