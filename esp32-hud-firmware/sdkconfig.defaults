# ESP32 HUD Helmet - Real Hardware SDK Configuration
# Target: ESP32-S3 R16N8 (16MB Flash + 8MB Octal PSRAM)

# Display: ST7789 for Real Hardware
CONFIG_HUD_DISPLAY_ST7789=y
CONFIG_HUD_DISPLAY_WIDTH=240
CONFIG_HUD_DISPLAY_HEIGHT=240
CONFIG_HUD_HAS_BACKLIGHT_PIN=y

# Wi-Fi: Change to match your access point
CONFIG_ESP_WIFI_SSID="Xomtrovuive"
CONFIG_ESP_WIFI_PASSWORD="11111111"
CONFIG_ESP_WIFI_MAX_RETRY=5

# HTTP Server
CONFIG_HTTPD_MAX_REQ_HDR_LEN=1024
CONFIG_HTTPD_MAX_URI_LEN=512

# Log level
CONFIG_LOG_DEFAULT_LEVEL_INFO=y
CONFIG_LOG_DEFAULT_LEVEL=3

# Compiler Optimization: use -O2 (PERF) to avoid GCC ICE bug in esp_lcd_panel_rgb.c with -Og
CONFIG_COMPILER_OPTIMIZATION_PERF=y

# CPU Frequency
CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ_240=y
CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ=240

# FreeRTOS
CONFIG_FREERTOS_HZ=1000

# Partition Table - Custom
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"

# Flash Size: 16MB for R16N8
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="16MB"

# PSRAM: 8MB Octal PSRAM for R16N8
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_SPEED_80M=y
CONFIG_SPIRAM_BOOT_INIT=y
CONFIG_SPIRAM_IGNORE_NOTFOUND=y
CONFIG_SPIRAM_USE_MALLOC=y

# LVGL Configuration
CONFIG_LV_CONF_SKIP=y
CONFIG_LV_COLOR_DEPTH_16=y
CONFIG_LV_COLOR_16_SWAP=y
CONFIG_LV_MEM_CUSTOM=y

# Fonts
CONFIG_LV_FONT_MONTSERRAT_12=y
CONFIG_LV_FONT_MONTSERRAT_16=y
CONFIG_LV_FONT_MONTSERRAT_24=y
CONFIG_LV_FONT_MONTSERRAT_32=y
CONFIG_LV_FONT_MONTSERRAT_48=y

CONFIG_HTTPD_WS_SUPPORT=y
