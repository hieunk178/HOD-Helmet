# ESP32 HUD Helmet - Wokwi Simulator SDK Configuration
# Copy this over sdkconfig.defaults before building for Wokwi

# Display: ILI9341 for Wokwi
CONFIG_HUD_DISPLAY_ILI9341=y
CONFIG_HUD_DISPLAY_WIDTH=320
CONFIG_HUD_DISPLAY_HEIGHT=240
CONFIG_HUD_HAS_BACKLIGHT_PIN=n

# Wi-Fi: Wokwi virtual network (open, no password)
CONFIG_ESP_WIFI_SSID="Wokwi-GUEST"
CONFIG_ESP_WIFI_PASSWORD=""
CONFIG_ESP_WIFI_MAX_RETRY=5

# HTTP Server
CONFIG_HTTPD_MAX_REQ_HDR_LEN=1024
CONFIG_HTTPD_MAX_URI_LEN=512

# Log level
CONFIG_LOG_DEFAULT_LEVEL_INFO=y
CONFIG_LOG_DEFAULT_LEVEL=3

# FreeRTOS
CONFIG_FREERTOS_HZ=1000

# Partition Table
CONFIG_PARTITION_TABLE_SINGLE_APP=y
